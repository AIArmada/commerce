    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-install-cmd": [
            "@php artisan commerce:boost-update --ansi"
        ],
        "post-update-cmd": [
            "@php artisan commerce:boost-update --ansi"
        ],
        "cs": [
            "rector",
            "pint",
            "npm run prettier"
        ],
        "pint": "pint",
        "rector": "rector",
        "test:pest": "pest --parallel",
        "test:phpstan": "phpstan analyse --level=6",
        "test": [
            "@test:pest",
            "@test:phpstan"
        ]
    }
