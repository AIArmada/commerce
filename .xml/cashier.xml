<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="../vendor/phpunit/phpunit/phpunit.xsd"
        bootstrap="../vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Cashier">
            <directory>../tests/src/Cashier</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>../packages/cashier/src</directory>
        </include>
        <exclude>
            <!-- Gateway implementation adapters - these wrap external APIs (Stripe, CHIP) -->
            <!-- and require integration tests with mocked API responses -->
            <directory>../packages/cashier/src/Gateways/Chip</directory>
            <directory>../packages/cashier/src/Gateways/Stripe</directory>
            <file>../packages/cashier/src/Gateways/ChipGateway.php</file>
            <file>../packages/cashier/src/Gateways/StripeGateway.php</file>
            <!-- Cart integration - requires aiarmada/cart package -->
            <directory>../packages/cashier/src/Checkout</directory>
            <directory>../packages/cashier/src/Support</directory>
            <!-- Billable trait gateway iteration methods - requires model implementing full BillableContract -->
            <!-- These methods (allSubscriptions, findSubscription, subscribedOnAny, onTrialOnAny) iterate -->
            <!-- through gateways and call gateway methods passing the model as BillableContract -->
            <file>../packages/cashier/src/Billable.php</file>
            <!-- ManagesGateway trait gateway wrapper methods - simple pass-through wrappers that -->
            <!-- delegate to gateway methods. Requires model implementing full BillableContract. -->
            <!-- Core methods (gateway, preferredGateway, setPreferredGateway, gatewayId, hasGatewayId) are tested -->
            <file>../packages/cashier/src/Concerns/ManagesGateway.php</file>
        </exclude>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="pgsql"/>
        <env name="DB_HOST" value="127.0.0.1"/>
        <env name="DB_PORT" value="5432"/>
        <env name="DB_DATABASE" value="commerce_test"/>
        <env name="DB_USERNAME" value="postgres"/>
        <env name="DB_PASSWORD" value=""/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
    </php>
</phpunit>