{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "php",
                "artisan",
                "boost:mcp"
            ]
        }
    },
    "provider": {
        "openrouter": {
            "models": {
                "deepseek/deepseek-v4-flash": {
                    "options": {
                        "provider": {
                            "order": ["baidu"],
                            "allow_fallbacks": false
                        }
                    }
                }
            }
        }
    }
}