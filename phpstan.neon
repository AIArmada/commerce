includes:
    - phpstan-baseline.neon

parameters:
    paths:
        - packages

    level: 6

    reportUnmatchedIgnoredErrors: true

    treatPhpDocTypesAsCertain: false

    parallel:
        maximumNumberOfProcesses: 4

    tmpDir: var/cache/phpstan

    # Ignore specific errors
    ignoreErrors:
        - identifier: 'missingType.generics'
        - identifier: 'larastan.noEnvCallsOutsideOfConfig'
        - identifier: 'return.unusedType'
        # Spatie packages are installed via require-dev; do not ignore missing class/trait errors
        # Missing type specifications in scope methods (legacy code)
        - identifier: 'missingType.return'
        - identifier: 'missingType.parameter'
                # Ignore example files that reference external dependencies
        # Ignore Filament v5 beta compatibility issues
        - message: '#Call to an undefined method.*Filament.*glow\(\)\.#'
        - message: '#Call to an undefined method.*Filament.*carded\(\)\.#'
        - message: '#Call to an undefined method.*Filament.*softShadow\(\)\.#'
        - message: '#Call to an undefined method.*Filament.*inlineLabelled\(\)\.#'
        # Filament v5 beta namespace reorganization - Tables\Actions moved to Actions namespace
        - message: '#Call to static method make\(\) on an unknown class Filament\\Tables\\Actions\\.*#'
        - message: '#Call to static method make\(\) on an unknown class Filament\\Notifications\\Actions\\.*#'
        - message: '#Parameter .* has invalid type Filament\\Forms\\Get\.#'
        - message: '#Parameter .* has invalid type Filament\\Forms\\Set\.#'
        - message: '#Invoking callable on an unknown class Filament\\Forms\\(Get|Set)\.#'
        - message: '#Method .* has invalid return type Filament\\Forms\\Form\.#'
        - message: '#Parameter .* has invalid type Filament\\Forms\\Form\.#'
        - message: '#Call to method .* on an unknown class Filament\\Forms\\Form\.#'
        - message: '#Access to an undefined property .*::\$form\.#'
        # Filament v5 Forms\Components not found (larastan resolution issue)
        - message: '#Call to static method make\(\) on an unknown class Filament\\Forms\\Components\\.*#'
        # Ignore property override issues in widgets
        # Ignore external cart model references
        - message: '#PHPDoc tag @var for variable.*contains unknown class.*Cart\.#'
        - message: '#PHPDoc tag @var with type.*Cart.*is not subtype of native type.*Model.*#'
        - message: '#Access to property.*on an unknown class.*Cart\.#'
        # Ignore Voucher model method calls (methods exist but PHPStan can't resolve them)
        # Ignore view function type issues
        - message: '#Parameter .* \$view of function view expects view-string\|null, string given\.#'
        # Ignore filament-permissions external dependencies
        - message: '#Call to an undefined method Illuminate\\Foundation\\Auth\\User::hasRole\(\)\.#'
        - message: '#Call to an undefined method Illuminate\\Foundation\\Auth\\User::hasAnyRole\(\)\.#'
        - message: '#Access to an undefined property Illuminate\\Database\\Eloquent\\Model::\$guard_name\.#'
        - message: '#Property .*\$view \(view-string\) does not accept default value of type string\.#'
        # Ignore unused traits in filament-authz (they're part of the public API)
        - message: '#Trait AIArmada\\FilamentAuthz\\Concerns\\.*is used zero times and is not analysed\.#'
        # Filament-authz Spatie Permission integration (methods come from HasRoles trait at runtime)
        - message: '#Call to an undefined method Illuminate\\Database\\Eloquent\\Model::syncPermissions\(\)\.#'
        - identifier: 'method.unused'
        # Ignore nullsafe warnings on eager loaded relations (PHPStan can't detect the with() call context)
        - identifier: 'nullsafe.neverNull'
        # Ignore scope return type issues (scopes return Builder<static> but PHPStan sees Builder<Model>)
        - message: '#Method AIArmada\\Inventory\\Models\\.*::scope.*should return Illuminate\\Database\\Eloquent\\Builder.*but returns Illuminate\\Database\\Eloquent\\Builder.*#'
        # Ignore mapWithKeys collection operation type issues
        # Ignore undefined scope method calls (scopes are dynamically resolved)
        - message: '#Call to an undefined method Illuminate\\Database\\Eloquent\\Builder.*::open\(\)\.#'
        - message: '#Call to an undefined method Illuminate\\Database\\Eloquent\\Builder.*::notExpiringSoon\(\)\.#'
        # Ignore Livewire v3 getLivewire() method (exists at runtime)
        - message: '#Call to an undefined method AIArmada\\FilamentCart\\Widgets\\.*::getLivewire\(\)\.#'
        # Ignore LengthAwarePaginator generic type issues
        - message: '#Generic type Illuminate\\Contracts\\Pagination\\LengthAwarePaginator.*does not specify all template types.*#'
        - message: '#Type.*in generic type Illuminate\\Contracts\\Pagination\\LengthAwarePaginator.*is not subtype of template type.*#'
        - message: '#Method AIArmada\\Inventory\\Services\\SerialLookupService::search\(\) should return.*LengthAwarePaginator.*but returns.*#'
        # Ignore missingType.iterableValue for metadata arrays
        - message: '#Method AIArmada\\Inventory\\Services\\StandardCostService::setStandardCost\(\) has parameter \$metadata with no value type specified in iterable type array\.#'
        # Ignore hasMany/belongsTo template type resolution with external models
        # Ignore identical return type covariance warnings (PHPStan bug with array shape types)
        - message: '#Method.*should return.*Collection.*array\{.*\}.*but returns.*Collection.*array\{.*\}.*#'
        - message: '#Anonymous function should return.*Collection.*array\{.*\}.*but returns.*Collection.*array\{.*\}.*#'
        - message: '#Parameter.*\$callback of method.*Collection.*map\(\) expects callable.*#'
        # Ignore test-specific issues
        # Ignore Faker method calls (methods exist but PHPStan can't resolve them)
        - message: '#Call to an undefined method Faker\\Generator::.*#'
        # Ignore unused traits in customers (public API for consumers)
        - message: '#Trait AIArmada\\Customers\\Concerns\\.*is used zero times and is not analysed\.#'
         # Ignore collection proxy method calls
        - message: '#Call to an undefined method Illuminate\\Support\\HigherOrderCollectionProxy.*::markAsRedeemed\(\)\.#'
        # Ignore return type covariance issues with Eloquent relations (PHPStan template variance)
        - message: '#Method.*should return.*Relations\\(HasMany|BelongsTo|MorphTo).*but returns.*Relations\\(HasMany|BelongsTo|MorphTo).*#'
        # Ignore missingType.iterableValue (array type specifications)
        - identifier: 'missingType.iterableValue'
        # Ignore unused traits (public API)
        - message: '#Trait AIArmada\\Vouchers\\Traits\\.*is used zero times and is not analysed\.#'
        - message: '#Trait AIArmada\\Vouchers\\GiftCards\\Traits\\.*is used zero times and is not analysed\.#'
        # Ignore relation existence errors (Larastan false positives)
        # Ignore cast.string for enums
        - message: '#Cannot cast AIArmada\\Affiliates\\Enums\\.*to string\.#'
        # Ignore match.unhandled for enums with new cases
        - identifier: 'match.unhandled'
        # Ignore property.onlyWritten (intentional design patterns)
        - identifier: 'property.onlyWritten'
        # Ignore return.type covariance issues
        - identifier: 'return.type'
        # Ignore argument.type for Filament closures
        - message: '#Parameter.*of method Illuminate\\Support\\Collection.*::each\(\) expects callable.*given\.#'
        # Ignore getDriverName method (exists in concrete implementation)
        - message: '#Call to an undefined method Illuminate\\Database\\ConnectionInterface::getDriverName\(\)\.#'
        # Ignore property.defaultValue issues
        - identifier: 'property.defaultValue'
        # Ignore arguments.count for context methods
        # Ignore CompoundVoucherCondition rules parameter type
        - message: '#Parameter \$rules of class AIArmada\\Cart\\Conditions\\CartCondition constructor expects.*#'
        # Ignore FilamentChip Jetstream/Cashier integration issues
        - message: '#Access to an undefined property Illuminate\\Foundation\\Auth\\User::\$currentTeam\.#'
        - message: '#Call to an undefined method Illuminate\\Database\\Eloquent\\Model::(updateDefaultPaymentMethod|deletePaymentMethod)\(\)\.#'
        # Ignore new.static (safe in our context)
        - identifier: 'new.static'
        # Ignore PHPDoc type issues in Cart traits
        - message: '#PHPDoc tag @param for parameter \$resolver with type.*is not subtype of native type callable\.#'
        # Ignore nullCoalesce in exception classes
        - identifier: 'nullCoalesce.expr'
        # Ignore strict comparison and deadCode in validators (defensive programming)
        - identifier: 'notIdentical.alwaysTrue'
        - identifier: 'deadCode.unreachable'
        - identifier: 'identical.alwaysFalse'
        - identifier: 'instanceof.alwaysTrue'
        # Ignore unused Buyable trait (it's part of the public API)
        - message: '#Trait AIArmada\\Cart\\Concerns\\Buyable is used zero times and is not analysed\.#'

        # Filament macros are dynamically bound at runtime (Macroable), PHPStan can't see $this
        - message: '#Undefined variable: \$this#'
          paths:
              - packages/filament-authz/src/Support/Macros

        # Optional dependencies (Stripe / Cashier)
        - identifier: 'class.notFound'
          paths:
              - packages/cashier/src/Gateways/Stripe
              - packages/cashier/src/Gateways/StripeGateway.php
              - packages/filament-cashier/src

        # Arguments count in Akaunting Money (version compatibility)
        - message: '#Method Akaunting\\Money\\Money::format\(\) invoked with 1 parameter.*#'

        # function.alreadyNarrowedType - defensive programming patterns
        - identifier: 'function.alreadyNarrowedType'
        - identifier: 'function.impossibleType'

        # throws.notThrowable - Exception class hierarchy issues
        - identifier: 'throws.notThrowable'

        # offsetAccess.nonOffsetAccessible - dynamic property access patterns
        - identifier: 'offsetAccess.nonOffsetAccessible'

        # argument.templateType - complex generic type resolution
        - identifier: 'argument.templateType'

        # argument.unknown - external class method calls
        - identifier: 'argument.unknown'

        # method.protected - false positives from trait usage
        - identifier: 'method.protected'

    # Exclude patterns
    excludePaths:
        analyseAndScan:
            - vendor
            - '*/Testing/*'
