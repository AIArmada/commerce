{
    "name": "aiarmada/orders",
    "description": "Order management and transaction lifecycle for the AIArmada Commerce ecosystem",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "laravel",
        "commerce",
        "orders",
        "transactions",
        "state-machine",
        "invoices"
    ],
    "authors": [
        {
            "name": "AIArmada",
            "email": "dev@aiarmada.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "aiarmada/commerce-support": "^1.0",
        "akaunting/laravel-money": "^5.0",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "spatie/laravel-model-states": "^2.0",
        "spatie/laravel-pdf": "^1.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "AIArmada\\Orders\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AIArmada\\Orders\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AIArmada\\Orders\\OrdersServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}