{
    "name": "aiarmada/filament-products",
    "description": "Filament admin panel for product catalog management",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "laravel",
        "filament",
        "products",
        "admin",
        "commerce"
    ],
    "authors": [
        {
            "name": "AIArmada",
            "email": "dev@aiarmada.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "aiarmada/products": "^1.0",
        "filament/filament": "^3.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "AIArmada\\FilamentProducts\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AIArmada\\FilamentProducts\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AIArmada\\FilamentProducts\\FilamentProductsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}