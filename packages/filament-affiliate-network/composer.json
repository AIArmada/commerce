{
  "name": "aiarmada/filament-affiliate-network",
  "description": "Filament admin plugin for managing AIArmada affiliate network marketplace.",
  "license": "MIT",
  "homepage": "https://github.com/aiarmada/commerce",
  "support": {
    "issues": "https://github.com/aiarmada/commerce/issues",
    "source": "https://github.com/aiarmada/commerce"
  },
  "require": {
    "aiarmada/commerce-support": "self.version",
    "aiarmada/affiliate-network": "self.version",
    "aiarmada/filament-affiliates": "self.version",
    "filament/filament": "^5.6.7",
    "php": "^8.4"
  },
  "autoload": {
    "psr-4": {
      "AIArmada\\FilamentAffiliateNetwork\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "AIArmada\\FilamentAffiliateNetwork\\FilamentAffiliateNetworkServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "suggest": {
    "aiarmada/affiliates": "Optional integration"
  }
}
