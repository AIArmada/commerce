{
    "name": "aiarmada/filament-cashier-chip",
    "description": "Filament admin panel for Cashier CHIP subscription billing management",
    "license": "MIT",
    "homepage": "https://github.com/aiarmada/commerce",
    "support": {
        "issues": "https://github.com/aiarmada/commerce/issues",
        "source": "https://github.com/aiarmada/commerce"
    },
    "require": {
        "aiarmada/cashier-chip": "self.version",
        "filament/filament": "^5.6"
    },
    "suggest": {
        "aiarmada/filament-chip": "Shared resources for Chip purchases",
        "aiarmada/filament-permissions": "Role-based access to billing features"
    },
    "autoload": {
        "psr-4": {
            "AIArmada\\FilamentCashierChip\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AIArmada\\FilamentCashierChip\\FilamentCashierChipServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
