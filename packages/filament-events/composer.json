{
    "name": "aiarmada/filament-events",
    "description": "Filament admin panel for event series, occurrences, venues, and registrations",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "laravel",
        "filament",
        "events",
        "admin",
        "commerce"
    ],
    "authors": [
        {
            "name": "AIArmada",
            "email": "dev@aiarmada.com"
        }
    ],
    "require": {
        "aiarmada/commerce-support": "self.version",
        "aiarmada/events": "self.version",
        "filament/filament": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "AIArmada\\FilamentEvents\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AIArmada\\FilamentEvents\\FilamentEventsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
