{
    "name": "aiarmada/authz",
    "description": "Generic Spatie Permission wrapper with scoped authorization and impersonation for Laravel applications.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "aiarmada/commerce-support": "self.version",
        "spatie/laravel-permission": "^8.0.0"
    },
    "autoload": {
        "psr-4": {
            "AIArmada\\Authz\\": "src/"
        },
        "files": ["src/helpers.php"]
    },
    "extra": {
        "laravel": {
            "providers": ["AIArmada\\Authz\\AuthzServiceProvider"]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
