{
    "name": "aiarmada/filament-feedback",
    "description": "Filament v5 admin adapter for aiarmada/feedback.",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "aiarmada/commerce-support": "self.version",
        "aiarmada/feedback": "self.version",
        "filament/filament": "^5.6.7"
    },
    "autoload": {
        "psr-4": {
            "AIArmada\\FilamentFeedback\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AIArmada\\FilamentFeedback\\FilamentFeedbackServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
