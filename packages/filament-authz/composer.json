{
    "name": "aiarmada/filament-authz",
    "description": "Filament v5 permissions suite powered by Spatie laravel-permission with multi-guard, panel-aware gating, and admin UX.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "aiarmada/authz": "self.version",
        "aiarmada/commerce-support": "self.version",
        "filament/filament": "^5.6.7",
        "spatie/laravel-permission": "^8.0.0"
    },
    "autoload": {
        "psr-4": {
            "AIArmada\\FilamentAuthz\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["AIArmada\\FilamentAuthz\\FilamentAuthzServiceProvider"]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
