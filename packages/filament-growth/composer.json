{
    "name": "aiarmada/filament-growth",
    "description": "Filament admin package for the AIArmada growth experimentation engine",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "laravel",
        "filament",
        "growth",
        "experimentation"
    ],
    "authors": [
        {
            "name": "AIArmada",
            "email": "dev@aiarmada.com"
        }
    ],
    "require": {
        "aiarmada/commerce-support": "self.version",
        "aiarmada/growth": "self.version",
        "filament/filament": "^5.6.7",
        "php": "^8.4"
    },
    "autoload": {
        "psr-4": {
            "AIArmada\\FilamentGrowth\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AIArmada\\FilamentGrowth\\FilamentGrowthServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
